#include <iostream>
using namespace std;

int main(){
    int age;
    cin>>age;
    
    if(age>=18){
        if(age>=100){
            cout<<"senior citeizen";
        } else {
            cout<<"eligible for vote";
        }
        
    } else {
        if(age <= 0){
            cout<< "enter a valid age number";
        } else{
            cout << "you are not eligible for vote";
        }
    }
